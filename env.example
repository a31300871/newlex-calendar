# ─────────────────────────────────────────────────
#  New Lexington Community Calendar – Environment
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# REQUIRED – change this to a long random string before going live
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Admin account password (used only on first run / DB seed)
# After first run, change the password via the UI or delete calendar.db to re-seed
ADMIN_PASSWORD=admin2024!

# Optional: restrict CORS to your domain in production
# ALLOWED_ORIGIN=https://www.newlexingtonohio.gov

# Optional: custom path for the SQLite database file
# DB_PATH=/var/data/calendar.db
