*{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px}
body{
  font-family:var(--font-body);background:var(--cream);color:var(--text);line-height:1.65;
  background-image:
    radial-gradient(ellipse 800px 600px at 0% 0%, rgba(99,102,241,.06), transparent 50%),
    radial-gradient(ellipse 800px 600px at 100% 30%, rgba(236,72,153,.05), transparent 50%),
    radial-gradient(ellipse 1000px 600px at 50% 100%, rgba(245,158,11,.04), transparent 50%);
  background-attachment:fixed;
}
nav{
  position:sticky;top:0;z-index:200;
  background:rgba(255,255,255,0.92);
  backdrop-filter:blur(20px) saturate(180%);
  -webkit-backdrop-filter:blur(20px) saturate(180%);
  border-bottom:1px solid var(--border);
  padding:14px 20px;
  box-shadow:0 1px 0 rgba(15,23,42,0.04),0 8px 24px -16px rgba(99,102,241,0.25);
}
nav::after{
  content:'';position:absolute;left:0;right:0;bottom:-3px;height:3px;
  background:var(--gradient);
  filter:blur(0.5px);
  box-shadow:0 0 18px rgba(99,102,241,0.45),0 0 30px rgba(236,72,153,0.3);
}
.nav-inner{max-width:920px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:16px}
.brand{font-family:var(--font-head);font-size:22px;font-weight:700;color:var(--text);text-decoration:none}
.brand-grad{background:var(--gradient);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;font-weight:800;letter-spacing:-.01em}
.spark{background:var(--gradient);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}
.back-btn{
  font-size:14px;color:var(--text2);text-decoration:none;
  padding:7px 14px;border-radius:100px;
  background:var(--surface);border:1.5px solid var(--border-md);
  font-weight:700;transition:all .2s;white-space:nowrap;
}
.back-btn:hover{color:var(--amber);background:var(--amber-lt);border-color:var(--amber);box-shadow:0 0 0 3px rgba(99,102,241,.1),0 4px 12px rgba(99,102,241,.15);transform:translateY(-1px)}

.draft-banner{
  background:linear-gradient(135deg,#FEF3C7 0%,#FDE68A 100%);
  border:1.5px solid #F59E0B;
  border-radius:var(--r);
  padding:14px 20px;
  margin:24px auto;
  max-width:880px;
  font-size:14px;
  color:#78350F;
  line-height:1.55;
  box-shadow:0 4px 16px rgba(245,158,11,.18);
}
.draft-banner strong{display:block;font-size:15px;margin-bottom:4px;color:#78350F}

.legal-wrap{max-width:880px;margin:0 auto;padding:32px 20px 80px}
.legal-wrap h1{font-family:var(--font-head);font-size:36px;font-weight:700;line-height:1.15;margin-bottom:8px;color:var(--text);letter-spacing:-.02em}
.legal-wrap .updated{font-size:13px;color:var(--text3);margin-bottom:32px;display:block;font-weight:600}
.legal-wrap h2{font-family:var(--font-head);font-size:24px;font-weight:700;margin:36px 0 12px;color:var(--text);letter-spacing:-.01em}
.legal-wrap h3{font-size:18px;font-weight:700;margin:24px 0 10px;color:var(--text)}
.legal-wrap p{margin-bottom:14px;color:var(--text2);font-size:16px}
.legal-wrap ul,.legal-wrap ol{margin:0 0 16px 22px;color:var(--text2)}
.legal-wrap li{margin-bottom:6px;font-size:16px}
.legal-wrap strong{color:var(--text)}
.legal-wrap a{color:var(--amber-dk);text-decoration:underline;font-weight:600}
.legal-wrap a:hover{color:var(--pink)}
.legal-wrap hr{margin:32px 0;border:none;border-top:1px solid var(--border)}
.legal-wrap .contact-box{background:var(--surface2);border-left:3px solid var(--amber);padding:14px 18px;border-radius:6px;margin:18px 0}
.legal-wrap .contact-box p{margin:0;font-size:15px}

footer{padding:32px 20px;text-align:center;border-top:1px solid var(--border);background:rgba(255,255,255,0.5);backdrop-filter:blur(8px);font-size:13px;color:var(--text3)}
footer a{color:var(--text2);text-decoration:none;font-weight:600;margin:0 8px;white-space:nowrap}
footer a:hover{color:var(--amber)}
footer .ft-links{display:flex;flex-wrap:wrap;justify-content:center;gap:4px 0;margin-bottom:14px;line-height:1.9}
footer .ft-mark{font-family:var(--font-head);font-weight:700;font-size:15px;margin-bottom:8px}
@media(max-width:600px){
  .legal-wrap h1{font-size:28px}
  .legal-wrap h2{font-size:21px}
  .legal-wrap p,.legal-wrap li{font-size:15px}
  .brand{font-size:18px}
}
